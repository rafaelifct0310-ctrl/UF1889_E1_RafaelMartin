<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista tree -->
    <record id="view_seguimiento_cliente_tree" model="ir.ui.view">
        <field name="name">seguimiento.cliente.tree</field>
        <field name="model">seguimiento.cliente</field>
        <field name="arch" type="xml">
            <list string="Seguimiento de Clientes" default_order="fecha desc">
                <field name="nombre"/>
                <field name="cliente_id"/>
                <field name="fecha"/>
                <field name="estado"/>
            </tree>
        </field>
    </record>

    <!-- Vista form -->
    <record id="view_seguimiento_cliente_form" model="ir.ui.view">
        <field name="name">seguimiento.cliente.form</field>
        <field name="model">seguimiento.cliente</field>
        <field name="arch" type="xml">
            <form string="Seguimiento de Clientes">
                <header>
                    <button name="action_marcar_realizado"
                            string="Marcar Realizado"
                            type="object"
                            class="oe_highlight"
                            invisible="estado == 'realizado'"/>
                    <field name="estado" widget="statusbar" statusbar_visible="pendiente,realizado"/>
                </header>
                <sheet>
                    <group>
                        <field name="nombre"/>
                        <field name="cliente_id"/>
                        <field name="fecha"/>
                        <field name="notas"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista search con filtro de pendientes -->
    <record id="view_seguimiento_cliente_search" model="ir.ui.view">
        <field name="name">seguimiento.cliente.search</field>
        <field name="model">seguimiento.cliente</field>
        <field name="arch" type="xml">
            <search string="Buscar Seguimiento">
                <filter name="pendientes"
                        string="Pendientes"
                        domain="[('estado', '=', 'pendiente')]"/>
                <field name="nombre"/>
                <field name="cliente_id"/>
            </search>
        </field>
    </record>

    <!-- Acción window -->
    <record id="action_seguimiento_cliente" model="ir.actions.act_window">
        <field name="name">Seguimiento de Clientes</field>
        <field name="res_model">seguimiento.cliente</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_pendientes': 1}</field>
    </record>

    <!-- Menú principal -->
    <menuitem id="menu_seguimiento_cliente"
              name="Seguimiento Clientes"
              action="action_seguimiento_cliente"
              parent="contacts.menu_contact"
              sequence="10"/>
</odoo>